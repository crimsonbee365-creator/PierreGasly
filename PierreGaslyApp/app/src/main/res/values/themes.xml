<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.PierreGasly" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/pg_primary</item>
        <item name="colorPrimaryDark">@color/pg_primary_dark</item>
        <item name="colorAccent">@color/pg_secondary</item>
        <item name="android:colorBackground">@color/background_light</item>
        <item name="android:windowBackground">@color/background_light</item>
        <item name="android:textColorPrimary">@color/text_primary_light</item>
        <item name="android:textColorSecondary">@color/text_secondary_light</item>
        <item name="android:statusBarColor">@color/background_light</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="colorSurface2">@color/surface_elevated</item>
        <item name="colorNavBackground">@color/surface_light</item>
        <item name="colorCardBackground">@color/surface_light</item>
    </style>

    <style name="Theme.PierreGasly.Dark" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/pg_accent</item>
        <item name="colorPrimaryDark">@color/pg_primary</item>
        <item name="colorAccent">@color/pg_secondary</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:textColorPrimary">@color/text_primary_dark</item>
        <item name="android:textColorSecondary">@color/text_secondary_dark</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorSurface2">@color/surface_dark</item>
        <item name="colorNavBackground">@color/nav_dark</item>
        <item name="colorCardBackground">@color/surface_dark</item>
    </style>

    <style name="Theme.PierreGasly.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/pg_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/pg_secondary</item>
        <item name="postSplashScreenTheme">@style/Theme.PierreGasly</item>
    </style>

    <style name="PG.InputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/pg_primary</item>
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="hintTextColor">@color/pg_primary</item>
    </style>

    <style name="PG.InputLayout.Dark" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">#7B5CF0</item>
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="hintTextColor">#7B5CF0</item>
        <item name="boxBackgroundColor">@color/surface_dark</item>
        <item name="android:textColorHint">@color/text_secondary_dark</item>
    </style>

    <style name="PG.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/pg_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="PG.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/pg_primary</item>
        <item name="android:textColor">@color/pg_primary</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

</resources>
