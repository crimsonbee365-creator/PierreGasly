<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="@drawable/bg_bottom_nav"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingHorizontal="8dp"
    android:weightSum="5">

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
        <ImageView android:id="@+id/navDashboard" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_nav_dashboard" android:contentDescription="Dashboard"/>
        <TextView android:id="@+id/navDashboardLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dashboard" android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
        <ImageView android:id="@+id/navProducts" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_nav_products" android:contentDescription="Products"/>
        <TextView android:id="@+id/navProductsLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Products" android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
        <ImageView android:id="@+id/navOrders" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_nav_orders" android:contentDescription="Orders"/>
        <TextView android:id="@+id/navOrdersLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Orders" android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
        <ImageView android:id="@+id/navRewards" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_nav_rewards" android:contentDescription="Rewards"/>
        <TextView android:id="@+id/navRewardsLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rewards" android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
        <ImageView android:id="@+id/navProfile" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_nav_profile" android:contentDescription="Profile"/>
        <TextView android:id="@+id/navProfileLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Profile" android:textSize="11sp" />
    </LinearLayout>

</LinearLayout>
