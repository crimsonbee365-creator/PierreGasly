<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground">

    <!-- ══════════════════════════════════════════════════════════
         SCROLLABLE BODY
    ══════════════════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── HERO HEADER ─────────────────────────────────── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="200dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_hero_gradient"/>

                <!-- decorative blobs -->
                <View
                    android:layout_width="180dp" android:layout_height="180dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-60dp" android:layout_marginEnd="-60dp"
                    android:background="#22FFFFFF"/>
                <View
                    android:layout_width="110dp" android:layout_height="110dp"
                    android:layout_gravity="bottom|start"
                    android:layout_marginBottom="-35dp" android:layout_marginStart="-35dp"
                    android:background="#22FFFFFF"/>

                <!-- back button -->
                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="44dp" android:layout_height="44dp"
                    android:layout_gravity="top|start"
                    android:layout_marginTop="48dp" android:layout_marginStart="16dp"
                    android:background="#33FFFFFF"
                    android:src="@android:drawable/ic_menu_revert"
                    android:padding="10dp"
                    android:contentDescription="Back"/>

                <!-- menu button -->
                <ImageButton
                    android:id="@+id/btnMenu"
                    android:layout_width="44dp" android:layout_height="44dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="48dp" android:layout_marginEnd="16dp"
                    android:background="#33FFFFFF"
                    android:src="@drawable/ic_hamburger_dark"
                    android:padding="10dp"
                    android:contentDescription="Menu"/>

                <!-- centred hero text -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CREATE ACCOUNT"
                        android:textColor="#FFFFFF"
                        android:textSize="26sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Join Pierre Gasly — fast LPG delivery"
                        android:textColor="#CCE0FF"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </FrameLayout>

            <!-- ── FORM BODY ────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="28dp"
                android:paddingBottom="40dp">

                <!-- ═══════════ SECTION: Personal Info ═══════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">
                    <View
                        android:layout_width="4dp" android:layout_height="18dp"
                        android:background="@color/pg_primary"
                        android:layout_marginEnd="10dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PERSONAL INFORMATION"
                        android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/pg_primary"
                        android:letterSpacing="0.08"/>
                </LinearLayout>

                <!-- Last Name -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilLastName"
                    style="@style/PG.InputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Last Name"
                    android:layout_marginBottom="14dp"
                    app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                    app:startIconTint="@color/pg_primary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etLastName"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:inputType="textPersonName|textCapWords"
                        android:imeOptions="actionNext"
                        android:singleLine="true"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- First Name -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilFirstName"
                    style="@style/PG.InputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="First Name"
                    android:layout_marginBottom="14dp"
                    app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                    app:startIconTint="@color/pg_primary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etFirstName"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:inputType="textPersonName|textCapWords"
                        android:imeOptions="actionNext"
                        android:singleLine="true"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Middle Initial + Suffix (same row, same height) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilMiddleInitial"
                        style="@style/PG.InputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:hint="M.I."
                        app:helperText="Use 2 CAPITAL letters (e.g., JC)"
                        app:helperTextTextColor="?android:textColorSecondary">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etMiddleInitial"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:inputType="textCapCharacters"
                            android:maxLength="2"
                            android:imeOptions="actionNext"
                            android:singleLine="true"
                            android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZ"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilSuffix"
                        style="@style/PG.InputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:layout_marginStart="8dp"
                        android:hint="Suffix"
                        app:helperText="Jr., Sr., II, III…"
                        app:helperTextTextColor="?android:textColorSecondary">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSuffix"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:inputType="textPersonName|textCapWords"
                            android:maxLength="10"
                            android:imeOptions="actionNext"
                            android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- ═══════════ SECTION: Contact ═══════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp"
                    android:layout_marginTop="8dp">
                    <View
                        android:layout_width="4dp" android:layout_height="18dp"
                        android:background="@color/pg_primary"
                        android:layout_marginEnd="10dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CONTACT DETAILS"
                        android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/pg_primary"
                        android:letterSpacing="0.08"/>
                </LinearLayout>

                <!-- Email -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEmail"
                    style="@style/PG.InputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Email Address"
                    android:layout_marginBottom="14dp"
                    app:startIconDrawable="@android:drawable/ic_dialog_email"
                    app:startIconTint="@color/pg_primary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:inputType="textEmailAddress"
                        android:imeOptions="actionNext"
                        android:singleLine="true"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Phone -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPhone"
                    style="@style/PG.InputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Phone Number"
                    android:layout_marginBottom="8dp"
                    app:prefixText="+63 "
                    app:prefixTextColor="@color/pg_primary"
                    app:startIconDrawable="@android:drawable/ic_menu_call"
                    app:startIconTint="@color/pg_primary"
                    app:helperText="Start with 9 — 10 digits total (e.g. 9171234567)"
                    app:helperTextTextColor="?android:textColorSecondary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPhone"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:inputType="number"
                        android:maxLength="10"
                        android:imeOptions="actionNext"
                        android:singleLine="true"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- ═══════════ SECTION: Security ═══════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp"
                    android:layout_marginTop="16dp">
                    <View
                        android:layout_width="4dp" android:layout_height="18dp"
                        android:background="@color/pg_primary"
                        android:layout_marginEnd="10dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SECURITY"
                        android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/pg_primary"
                        android:letterSpacing="0.08"/>
                </LinearLayout>

                <!-- Password -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPassword"
                    style="@style/PG.InputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Password"
                    android:layout_marginBottom="6dp"
                    app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
                    app:startIconTint="@color/pg_primary"
                    app:endIconMode="password_toggle"
                    app:errorIconDrawable="@null"
                    app:helperText="8+ chars · uppercase · lowercase · number · special character"
                    app:helperTextTextColor="?android:textColorSecondary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:inputType="textPassword"
                        android:imeOptions="actionNext"
                        android:singleLine="true"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password strength bar -->
                <LinearLayout
                    android:id="@+id/passwordStrengthBar"
                    android:layout_width="match_parent"
                    android:layout_height="5dp"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="2dp">
                    <View android:id="@+id/strengthSegment1"
                        android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:background="#E0E0E0"
                        android:layout_marginEnd="3dp"/>
                    <View android:id="@+id/strengthSegment2"
                        android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:background="#E0E0E0"
                        android:layout_marginEnd="3dp"/>
                    <View android:id="@+id/strengthSegment3"
                        android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:background="#E0E0E0"
                        android:layout_marginEnd="3dp"/>
                    <View android:id="@+id/strengthSegment4"
                        android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:background="#E0E0E0"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvPasswordStrength"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="11sp"
                    android:gravity="end"
                    android:visibility="gone"
                    android:layout_marginBottom="12dp"/>

                <!-- Confirm Password -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilConfirmPassword"
                    style="@style/PG.InputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Confirm Password"
                    android:layout_marginBottom="22dp"
                    app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
                    app:startIconTint="@color/pg_primary"
                    app:endIconMode="password_toggle"
                    app:errorIconDrawable="@null">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:inputType="textPassword"
                        android:imeOptions="actionDone"
                        android:singleLine="true"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Error banner -->
                <TextView
                    android:id="@+id/tvError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/error"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:background="@color/error_soft"
                    android:maxLines="3"
                    android:ellipsize="end"
                    android:padding="12dp"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp"/>

                <!-- Create Account button -->
                <Button
                    android:id="@+id/btnSignUp"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="CREATE ACCOUNT"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.03"
                    android:background="@drawable/bg_button_gradient"
                    android:stateListAnimator="@null"/>

                <!-- Spinner -->
                <ProgressBar
                    android:id="@+id/signupProgress"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:indeterminateDrawable="@drawable/anim_loading_ring"
                    android:visibility="gone"
                    android:layout_marginTop="10dp"/>

                <!-- Divider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="16dp">
                    <View android:layout_width="0dp" android:layout_height="1dp"
                        android:layout_weight="1" android:background="@color/divider_light"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="  or  "
                        android:textColor="?android:textColorSecondary" android:textSize="12sp"/>
                    <View android:layout_width="0dp" android:layout_height="1dp"
                        android:layout_weight="1" android:background="@color/divider_light"/>
                </LinearLayout>

                <!-- Login link -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="center">
                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Already have an account?  "
                        android:textSize="14sp"
                        android:textColor="?android:textColorSecondary"/>
                    <TextView
                        android:id="@+id/tvLogin"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Sign In"
                        android:textColor="@color/pg_primary"
                        android:textSize="14sp" android:textStyle="bold"
                        android:clickable="true" android:focusable="true"/>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ══ DIM OVERLAY ══ -->
    <View android:id="@+id/drawerOverlay"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="@color/overlay_dark"
        android:visibility="gone"
        android:clickable="true" android:focusable="true"/>

    <!-- ══ DRAWER PANEL ══ -->
    <LinearLayout android:id="@+id/menuDrawer"
        android:layout_width="280dp" android:layout_height="match_parent"
        android:layout_gravity="end" android:orientation="vertical"
        android:background="?attr/colorNavBackground"
        android:paddingTop="56dp" android:paddingLeft="20dp" android:paddingRight="20dp"
        android:elevation="24dp" android:visibility="gone">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:gravity="end" android:layout_marginBottom="20dp">
            <ImageButton android:id="@+id/btnCloseMenu"
                android:layout_width="36dp" android:layout_height="36dp"
                android:background="?attr/colorSurface2"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:padding="8dp" android:contentDescription="Close"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="🌙  Dark Mode"
                android:textColor="?android:textColorPrimary" android:textSize="15sp"/>
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchTheme"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                app:thumbTint="@color/pg_primary"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider_light"
            android:layout_marginTop="8dp" android:layout_marginBottom="8dp"/>

        <LinearLayout android:id="@+id/menuAbout"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ℹ️" android:textSize="18sp" android:layout_marginEnd="14dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="About Us" android:textColor="?android:textColorPrimary" android:textSize="15sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/menuContact"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📞" android:textSize="18sp" android:layout_marginEnd="14dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Contact Us" android:textColor="?android:textColorPrimary" android:textSize="15sp"/>
        </LinearLayout>

        <View android:id="@+id/menuLogoutDivider"
            android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider_light"
            android:layout_marginTop="8dp" android:layout_marginBottom="8dp"
            android:visibility="gone"/>

        <LinearLayout android:id="@+id/menuLogout"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:clickable="true" android:focusable="true" android:visibility="gone">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🚪" android:textSize="18sp" android:layout_marginEnd="14dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Log Out" android:textColor="@color/error"
                android:textSize="15sp" android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
